# ==============================================================================
# ProImg — single root .env (all services load this automatically)
# ==============================================================================
#   cp .env.example .env
#
# Optional: services/<name>/.env can override PORT or MONGO_URI for that service only.
# ==============================================================================

NODE_ENV=development

# MongoDB Atlas or local — one URL for all services (each service uses its own database name)
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority

# Or set a full URI per service in services/<name>/.env as MONGO_URI=...

# Auth & sessions
JWT_SEC=your-jwt-secret
REFRESH_TOKEN_SEC=your-refresh-secret
SESSION_SECRET=your-session-secret

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_ProImgKey123
RAZORPAY_KEY_SECRET=ProImgSecret123456789

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
CLIENT_URL=http://localhost:5173

# Cloudinary (pin-service)
Cloud_Name=your-cloudinary-cloud-name
Cloud_Api=your-cloudinary-api-key
Cloud_Secret=your-cloudinary-api-secret

# Email (notification-service)
MY_GMAIL=your-account@gmail.com
MY_PASS=your-app-password
Isrender=false
RESEND_API_KEY=re_your_api_key
RESEND_FROM=onboarding@resend.dev


# Service ports (optional — defaults shown)
GATEWAY_PORT=5005
AUTH_PORT=5001
PIN_PORT=5002
CHAT_PORT=5003
NOTIFICATION_PORT=5006

# Or set PORT=5005 in root for gateway only (other services use AUTH_PORT, etc.)

# Gateway upstream URLs (optional overrides)
AUTH_SERVICE_URL=http://localhost:5001
PIN_SERVICE_URL=http://localhost:5002
CHAT_SERVICE_URL=http://localhost:5003
NOTIFICATION_SERVICE_URL=http://localhost:5006
FRONTEND_URL=http://localhost:5173

# Notification jobs
NOTIFICATION_RETENTION_DAYS=30
DIGEST_LOOKBACK_DAYS=7
CRON_TZ=UTC
# Fast cron for local testing (cleanup every 2m, digest every 3m, auto-runs once on startup)
CRON_FAST=true

# Frontend bell poll (ms) — default 10s in dev, 30s in production
# VITE_NOTIFICATION_POLL_MS=10000
