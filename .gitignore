# ProImg monorepo — services/* microservices + frontend (Vite)

# --- Dependencies (root, frontend, every service) ---
node_modules/

# --- Environment & secrets (templates stay tracked) ---
.env
.env.*
!.env.example
!**/.env.example

# --- Build outputs ---
dist/
dist-ssr/
build/
frontend/dist/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test / coverage ---
coverage/
.nyc_output/

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors ---
.idea/
.vscode/
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Local tooling (optional) ---
.planning/
.cache/
.vercel/
